# === Frontend Environment Variables ===
#
# Copy this file to .env.local for local development
# For Vercel deployment, set these in the Vercel dashboard (Settings → Environment Variables)

# Backend API URL
# Local: http://localhost:4000/api/v1
# Production: https://quicktask-api.onrender.com/api/v1 (your Render URL)
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Stripe (get from dashboard.stripe.com)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key-here"
